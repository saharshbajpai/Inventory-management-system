# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/inventory_db

# Backend Configuration
BACKEND_PORT=8000
# Local dev: http://localhost:3000
# Production: your Vercel URL (e.g. https://your-app.vercel.app)
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
# Local dev: http://localhost:8000
# Production build: your Render backend URL (e.g. https://your-api.onrender.com)
VITE_API_BASE_URL=http://localhost:8000

# Docker Hub (for submission)
# DOCKERHUB_USER=your-dockerhub-username
